VITE_AI_PROVIDER=pollinations

# Production:
# Frontend sends AI HTTP and websocket requests to the same host:
# POST /api/ai/pollinations
# WS   /ws/ai/queue
# Nginx must proxy these routes to Node-RED.
VITE_AI_PROXY_PROVIDER=same-origin

# Local development:
# Vite proxies same-origin requests to Node-RED.
# Keep these values only in .env.local.
# VITE_AI_PROXY_TARGET_ENDPOINT=https://92.63.98.81:1881/api/ai/pollinations
# VITE_AI_QUEUE_WS_TARGET_ENDPOINT=wss://92.63.98.81:1881/ws/ai/queue
# VITE_AI_PROXY_REJECT_UNAUTHORIZED=false

# Alternative browser-side provider:
# VITE_AI_PROVIDER=puter
# VITE_PUTER_AI_MODEL=gpt-5-nano
